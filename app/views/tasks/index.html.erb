<div class="task-layout">

  <aside class="sidebar">
    <h2>Task</h2>

    <ul>
      <li>ホーム</li>
      <li>タスク</li>
      <li>カレンダー</li>
      <li>設定</li>
    </ul>
  </aside>

  <main class="task-main">

    <div class="task-header">
      <h1>タスク管理</h1>

      <button>＋ タスク作成</button>
    </div>

    <div class="task-columns">

      <div class="task-column high">
        <h2>高</h2>

        <% @high_tasks.each do |task| %>
          <div class="task-card">
            <p><%= task.title %></p>
          </div>
        <% end %>
      </div>

      <div class="task-column medium">
        <h2>中</h2>

        <% @medium_tasks.each do |task| %>
          <div class="task-card">
            <p><%= task.title %></p>
          </div>
        <% end %>
      </div>

      <div class="task-column low">
        <h2>低</h2>

        <% @low_tasks.each do |task| %>
          <div class="task-card">
            <p><%= task.title %></p>
          </div>
        <% end %>
      </div>

    </div>
  </main>
</div>