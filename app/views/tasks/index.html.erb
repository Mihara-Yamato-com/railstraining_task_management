<h1>タスク一覧</h1>

<% if notice %>
  <p style="color: green;"><%= notice %></p>
<% end %>

<%= link_to "新しいタスクを追加", new_task_path %>

<table>
  <thead>
    <tr>
      <th>タイトル</th>
      <th>優先度</th>
      <th>期限</th>
      <th>完了</th>
      <th>操作</th>
    </tr>
  </thead>
  <tbody>
    <% @tasks.each do |task| %>
      <tr>
        <td><%= task.title %></td>
        <td><%= task.priority_label %></td>
        <td><%= task.due_date %></td>
        <td><%= task.done ? "✅" : "❌" %></td>
        <td>
          <%= link_to "詳細", task_path(task) %>
          <%= link_to "編集", edit_task_path(task) %>
          <%= link_to "削除", task_path(task), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>