<%= form_with model: task do |f| %>
  <% if task.errors.any? %>
    <ul>
      <% task.errors.full_messages.each do |msg| %>
        <li style="color: red;"><%= msg %></li>
      <% end %>
    </ul>
  <% end %>

  <div>
    <%= f.label :title, "タイトル" %>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :description, "説明" %>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.label :priority, "優先度" %>
    <%= f.select :priority, [["低", 1], ["中", 2], ["高", 3]] %>
  </div>

  <div>
    <%= f.label :due_date, "期限" %>
    <%= f.date_field :due_date %>
  </div>

  <div>
    <%= f.label :done, "完了" %>
    <%= f.check_box :done %>
  </div>

  <%= f.submit "保存" %>
<% end %>